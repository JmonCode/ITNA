# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAILS=smily094@gmail.com

# Supabase client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Supabase access. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI embeddings
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Storage
SUPABASE_STORAGE_PRODUCT_IMAGES_BUCKET=product-images

# Optional local automation / deployment
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# OAuth provider secrets are configured in the Supabase dashboard, not in this app.
# Required providers for V1: Email, Google, Kakao.
